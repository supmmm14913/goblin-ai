# ═══ 必填 ════════════════════════════════════════
PORT=5000
JWT_SECRET=換一個複雜的隨機字串_至少32字元
REPLICATE_API_TOKEN=r8_你的token
CLIENT_URL=https://goblinai.com

# ═══ 付款（Paddle）════════════════════════════════
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_STARTER=
PADDLE_PRICE_POPULAR=
PADDLE_PRICE_PRO=

# ═══ 寄信（二選一）══════════════════════════════
# 【推薦】Resend（免費 3000 封/月，去 resend.com 取得）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev   # 或你自己的網域信箱

# 【備選】Gmail SMTP（需開啟兩步驟驗證並建立應用程式密碼）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=你的gmail@gmail.com
SMTP_PASS=應用程式密碼16碼
